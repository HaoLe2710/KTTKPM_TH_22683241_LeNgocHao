<%- include("layout", { title: "Dashboard", body: `
  <h2>📊 Dashboard (Protected)</h2>
  <div class="box">
    <p><strong>Note:</strong> This page requires a valid access token. If it expires, you'll be redirected to login.</p>
    
    <div style="background: #f0f7ff; border-left: 4px solid #667eea; padding: 16px; border-radius: 6px; margin: 16px 0;">
      <strong style="color: #667eea;">ℹ️ Protected Route</strong>
      <p style="color: #555; margin-top: 8px;">This page uses <code style="background: white; padding: 2px 6px; border-radius: 4px;">requireAuth</code> middleware to verify your access token is valid.</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-top: 20px;">
      <button onclick="callProtected()">📡 Call /api/protected</button>
      <button onclick="doRefresh()">🔄 Refresh Token</button>
      <button onclick="doLogout()" class="danger">🚪 Logout</button>
    </div>
  </div>
`}) %>
